{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Site (Python)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "Presentation Only",
      "runtimeExecutable": "python3",
